# AI Cloud Cost Detective — Environment Variables

# ─── AI Provider: "gemini" or "groq" ───
AI_PROVIDER=gemini

# ─── Google Gemini (used when AI_PROVIDER=gemini) ───
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ─── Groq (used when AI_PROVIDER=groq) ───
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── PostgreSQL (Docker container) ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cost_detective

# ─── Authentication ───
JWT_SECRET=super_secret_jwt_key_change_me
